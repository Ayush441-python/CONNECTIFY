generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                String             @id @default(uuid())
  email             String             @unique
  mobile            String?            @unique
  password          String?
  role              Role
  isEmailVerified   Boolean            @default(false)
  isActive          Boolean            @default(true)
  isSuspended       Boolean            @default(false)
  emailVerifyToken  String?
  emailVerifyExpiry DateTime?
  resetToken        String?
  resetTokenExpiry  DateTime?
  lastLoginAt       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  authProvider      AuthProvider       @default(LOCAL)
  avatarUrl         String?
  googleId          String?            @unique
  brandProfile      BrandProfile?
  influencerProfile InfluencerProfile?
  receivedMessages  Message[]          @relation("ReceivedMessages")
  sentMessages      Message[]          @relation("SentMessages")
  notifications     Notification[]
  refreshTokens     RefreshToken[]
  reportsAgainst    Report[]           @relation("ReportedUser")
  reportsMade       Report[]           @relation("ReporterUser")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model InfluencerProfile {
  id                    String                 @id @default(uuid())
  userId                String                 @unique
  name                  String
  username              String                 @unique
  instagramUsername     String?
  city                  String?
  state                 String?
  country               String?
  categories            String[]               @default([])
  languages             String[]               @default([])
  tier                  InfluencerTier         @default(NANO)
  availability          Availability           @default(AVAILABLE)
  bio                   String?
  profilePhotoUrl       String?
  featuredCoverUrl      String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  applications          CampaignApplication[]
  collaborationRequests CollaborationRequest[]
  collaborations        Collaboration[]
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioImages       PortfolioImage[]
  savedCampaigns        SavedCampaign[]
  savedByBrands         SavedCreator[]

  @@index([city, state, country])
  @@index([tier, availability])
  @@map("influencer_profiles")
}

model BrandProfile {
  id                    String                 @id @default(uuid())
  userId                String                 @unique
  brandName             String
  logoUrl               String?
  industry              String?
  about                 String?
  website               String?
  city                  String?
  state                 String?
  country               String?
  preferredCategories   String[]               @default([])
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  campaigns             Campaign[]
  collaborationRequests CollaborationRequest[]
  collaborations        Collaboration[]
  savedCreators         SavedCreator[]

  @@map("brand_profiles")
}

model PortfolioImage {
  id           String            @id @default(uuid())
  influencerId String
  imageUrl     String
  caption      String?
  category     String?
  featured     Boolean           @default(false)
  createdAt    DateTime          @default(now())
  influencer   InfluencerProfile @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@index([influencerId])
  @@map("portfolio_images")
}

model Campaign {
  id              String                   @id @default(uuid())
  brandId         String
  title           String
  description     String
  category        String
  budgetMin       Float?
  budgetMax       Float?
  location        String?
  deadline        DateTime?
  creatorsNeeded  Int                      @default(1)
  status          CampaignStatus           @default(DRAFT)
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  applications    CampaignApplication[]
  deliverables    CampaignDeliverable[]
  moodboardImages CampaignMoodboardImage[]
  brand           BrandProfile             @relation(fields: [brandId], references: [id], onDelete: Cascade)
  collaborations  Collaboration[]
  savedBy         SavedCampaign[]

  @@index([category, status])
  @@index([status, createdAt])
  @@map("campaigns")
}

model CampaignMoodboardImage {
  id         String   @id @default(uuid())
  campaignId String
  imageUrl   String
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_moodboard_images")
}

model CampaignDeliverable {
  id          String   @id @default(uuid())
  campaignId  String
  description String
  quantity    Int      @default(1)
  campaign    Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_deliverables")
}

model CampaignApplication {
  id            String            @id @default(uuid())
  campaignId    String
  influencerId  String
  message       String
  expectedPrice Float?
  status        ApplicationStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  campaign      Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  influencer    InfluencerProfile @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  collaboration Collaboration?

  @@unique([campaignId, influencerId])
  @@index([campaignId])
  @@index([influencerId])
  @@map("campaign_applications")
}

model CollaborationRequest {
  id            String            @id @default(uuid())
  brandId       String
  influencerId  String
  campaignName  String
  message       String
  budget        Float?
  deliverables  String[]          @default([])
  status        RequestStatus     @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  brand         BrandProfile      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  influencer    InfluencerProfile @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  collaboration Collaboration?

  @@index([brandId])
  @@index([influencerId])
  @@map("collaboration_requests")
}

model Collaboration {
  id            String                @id @default(uuid())
  brandId       String
  influencerId  String
  campaignId    String?
  applicationId String?               @unique
  requestId     String?               @unique
  status        CollaborationStatus   @default(ACTIVE)
  notes         String?
  deadline      DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  files         CollaborationFile[]
  application   CampaignApplication?  @relation(fields: [applicationId], references: [id])
  brand         BrandProfile          @relation(fields: [brandId], references: [id], onDelete: Cascade)
  campaign      Campaign?             @relation(fields: [campaignId], references: [id])
  influencer    InfluencerProfile     @relation(fields: [influencerId], references: [id], onDelete: Cascade)
  request       CollaborationRequest? @relation(fields: [requestId], references: [id])
  messages      Message[]

  @@map("collaborations")
}

model CollaborationFile {
  id              String        @id @default(uuid())
  collaborationId String
  fileUrl         String
  name            String
  uploadedById    String
  createdAt       DateTime      @default(now())
  collaboration   Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)

  @@index([collaborationId])
  @@map("collaboration_files")
}

model Message {
  id              String        @id @default(uuid())
  collaborationId String
  senderId        String
  receiverId      String
  content         String?
  imageUrl        String?
  isRead          Boolean       @default(false)
  createdAt       DateTime      @default(now())
  collaboration   Collaboration @relation(fields: [collaborationId], references: [id], onDelete: Cascade)
  receiver        User          @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  sender          User          @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([collaborationId, createdAt])
  @@map("messages")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model SavedCreator {
  id           String            @id @default(uuid())
  brandId      String
  influencerId String
  createdAt    DateTime          @default(now())
  brand        BrandProfile      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  influencer   InfluencerProfile @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@unique([brandId, influencerId])
  @@map("saved_creators")
}

model SavedCampaign {
  id           String            @id @default(uuid())
  influencerId String
  campaignId   String
  createdAt    DateTime          @default(now())
  campaign     Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  influencer   InfluencerProfile @relation(fields: [influencerId], references: [id], onDelete: Cascade)

  @@unique([influencerId, campaignId])
  @@map("saved_campaigns")
}

model Report {
  id             String       @id @default(uuid())
  reporterId     String
  reportedUserId String?
  reason         String
  details        String?
  status         ReportStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  reportedUser   User?        @relation("ReportedUser", fields: [reportedUserId], references: [id], onDelete: Cascade)
  reporter       User         @relation("ReporterUser", fields: [reporterId], references: [id], onDelete: Cascade)

  @@map("reports")
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum Role {
  BRAND
  INFLUENCER
  ADMIN
}

enum InfluencerTier {
  NANO
  MICRO
  MACRO
  MEGA
}

enum Availability {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  CLOSED
  COMPLETED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum CollaborationStatus {
  ACTIVE
  COMPLETED
}

enum NotificationType {
  APPLICATION_RECEIVED
  APPLICATION_ACCEPTED
  APPLICATION_REJECTED
  REQUEST_RECEIVED
  REQUEST_ACCEPTED
  REQUEST_REJECTED
  NEW_MESSAGE
  NEW_CAMPAIGN
  SYSTEM
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}
