# --- Server ---
NODE_ENV=development
PORT=5000

# --- Database (Supabase: click "Connect" on your project dashboard. Use the direct connection,
# port 5432 — Render runs this as one persistent process, so no pooler is needed) ---
DATABASE_URL="postgresql://postgres:password@localhost:5432/connectify_dev"

# --- JWT ---
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# --- CORS / Client ---
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173
CLIENT_URL=http://localhost:5173

# --- Cloudinary (cloudinary.com dashboard) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- SMTP (optional in dev — emails log to console if unset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Connectify <no-reply@connectify.app>"

# --- Seed admin account (used by `npm run seed`) ---
ADMIN_EMAIL=admin@connectify.app
ADMIN_PASSWORD=ChangeMe123!
GOOGLE_CLIENT_ID=your_google_client_id_here